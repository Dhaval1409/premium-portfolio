@baseUrl = http://localhost:5000/api

### 1. LOGIN ENGINE (Authenticating with password 'spiderman')
# @name loginRequest
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@yourdomain.com",
  "password": "spiderman"
}

### Dynamically capture the generated JWT token from the response body
@adminToken = {{loginRequest.response.body.token}}


### =========================================================================
### 2. SEED MARVEL CINEMA RELEASE (Category: movies)
### =========================================================================
POST {{baseUrl}}/blogs
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "title": "Spider-Man: Beyond the Spider-Verse Release Date & Plot Predictions",
  "slug": "spiderman-beyond-the-spider-verse-release-tracker",
  "summary": "Everything we know about the epic conclusion to Miles Morales' trilogy, theatrical release updates, and deep-dive multiversal plot armor theories.",
  "category": "movies",
  "coverImage": "https://images.unsplash.com/photo-1635805737707-575885ab0820",
  "content": "The multiversal animated saga is heading toward its ultimate endgame. Following the cliffhanger of the previous chapter, fans globally are mapping out timelines waiting for the spectacular arrival of Beyond the Spider-Verse.",
  "readTime": "6 min read",
  "tags": ["Spider-Man", "Marvel", "Sony Pictures", "Cinema"]
}


### =========================================================================
### 3. SEED K-DRAMA CAST TRACKER (Category: drama)
### =========================================================================
POST {{baseUrl}}/blogs
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "title": "Lovely Runner: Complete Cast Breakdowns & Character Relationships",
  "slug": "lovely-runner-k-drama-cast-analysis",
  "summary": "A deep look into the breakout cast of the ultimate time-slip romance drama, profiling Ryu Sun-jae, Im Sol, and the stellar supporting crew.",
  "category": "drama",
  "coverImage": "https://images.unsplash.com/photo-1517604931442-7e0c8ed2963c",
  "content": "Lovely Runner has completely dominated global streaming charts. Let's dissect the brilliant performances behind these iconic characters.",
  "readTime": "5 min read",
  "tags": ["Lovely Runner", "tvN", "K-Drama", "Byeon Woo-seok", "Kim Hye-yoon"]
}